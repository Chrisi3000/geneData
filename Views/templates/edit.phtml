<?php include __DIR__ . "/_header.phtml"; ?>
<?php
$gene = $data['gene'];
$organisms = $data['organisms'];
?>

    <a href="/geneData/GeneDataItem"
       class="btn btn-outline-success rounded-pill px-3 mb-3">
        &#8592; Back
    </a>

    <h2>Edit Gene: <?= htmlspecialchars($gene->genename) ?></h2>

    <form id="editGeneForm">
        <input type="hidden" name="id" id="geneId" value="<?= (int)$gene->id ?>">

        <div class="mb-3">
            <label>Gene Name</label>
            <input type="text" name="genename" class="form-control" value="<?= htmlspecialchars($gene->genename) ?>" required>
        </div>

        <div class="mb-3">
            <label>Gene Symbol</label>
            <input type="text" name="genesymbol" class="form-control" value="<?= htmlspecialchars($gene->genesymbol) ?>" required>
        </div>

        <div class="mb-3">
            <label>Aliases</label>
            <input type="text" name="aliases" class="form-control" value="<?= htmlspecialchars($gene->aliases ?? '') ?>">
        </div>

        <div class="mb-3">
            <label>Position</label>
            <input type="text" name="position" class="form-control" value="<?= htmlspecialchars($gene->position) ?>" required>
        </div>

        <div class="mb-3">
            <label>Function</label>
            <textarea name="function" class="form-control"><?= htmlspecialchars($gene->function ?? '') ?></textarea>
        </div>

        <div class="mb-3">
            <label>Organism</label>
            <select name="organism_id" class="form-select" required>
                <?php foreach ($organisms as $organism): ?>
                    <option value="<?= (int)$organism->id ?>" <?= (int)$organism->id === (int)$gene->organism_id ? 'selected' : '' ?>>
                        <?= htmlspecialchars($organism->name) ?>
                    </option>
                <?php endforeach; ?>
            </select>
        </div>

        <div class="mb-3 form-check">
            <input type="checkbox" name="reviewed" class="form-check-input" id="reviewed" <?= $gene->reviewed ? 'checked' : '' ?>>
            <label class="form-check-label" for="reviewed">Reviewed</label>
        </div>

        <button type="submit" class="btn btn-primary">Save Changes</button>
    </form>

    <script>
        document.getElementById('editGeneForm').addEventListener('submit', function(e) {
            e.preventDefault();

            const id = document.getElementById('geneId').value;

            // automatically gathers all fields with a name attribute
            const payload = Object.fromEntries(new FormData(e.target));

            // fix checkbox behavior
            payload.reviewed = document.getElementById('reviewed').checked ? "1" : "0";

            // send AJAX request
            fetch("/geneData/GeneDataItem/" + id, {
                method: "PUT",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            })
                .then(async res => {
                    if (res.ok) {
                        window.location.href = "/geneData/GeneDataItem/" + id;
                    } else {
                        const err = await res.json().catch(() => ({}));
                        alert("Error: " + (err.error || "server error"));
                    }
                })
                .catch(() => alert("No connection to the server could be built."));
        });
    </script>

