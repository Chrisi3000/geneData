<?php include __DIR__ . "/_header.phtml"; ?>
<?php
$gene = $data['gene'];
$organisms = $data['organisms'];
?>

    <a href="/geneData/GeneDataItem"
       class="btn btn-outline-success rounded-pill px-3 mb-3">
        &#8592; Back
    </a>

    <h2>Edit Gene: <?= htmlspecialchars($gene->genename) ?></h2>

    <form id="editGeneForm" class="needs-validation was-validated" novalidate>
        <input type="hidden" name="id" id="geneId" value="<?= (int)$gene->id ?>">

        <div class="mb-3">
            <label class="form-label">Gene Name</label>
            <input type="text" name="genename" class="form-control" value="<?= htmlspecialchars($gene->genename) ?>" minlength="2" maxlength="255" required>
            <div class="invalid-feedback">please enter a valid gene name (min 2 characters).</div>
        </div>

        <div class="mb-3">
            <label class="form-label">Gene Symbol</label>
            <input type="text" name="genesymbol" class="form-control" value="<?= htmlspecialchars($gene->genesymbol) ?>" pattern="[A-Za-z0-9\-]{2,20}" required>
            <div class="invalid-feedback">please enter a valid symbol (2-20 alphanumeric characters or hyphens).</div>
        </div>

        <div class="mb-3">
            <label class="form-label">Aliases</label>
            <input type="text" name="aliases" class="form-control" value="<?= htmlspecialchars($gene->aliases ?? '') ?>" maxlength="255">
        </div>

        <div class="mb-3">
            <label class="form-label">Position</label>
            <input type="text" name="position" class="form-control" value="<?= htmlspecialchars($gene->position) ?>" minlength="3" maxlength="100" required>
            <div class="invalid-feedback">please specify the chromosomal position profile mapping.</div>
        </div>

        <div class="mb-3">
            <label class="form-label">Function</label>
            <textarea name="function" class="form-control" maxlength="500"><?= htmlspecialchars($gene->function ?? '') ?></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Organism</label>
            <select name="organism_id" class="form-select" required>
                <?php foreach ($organisms as $organism): ?>
                    <option value="<?= (int)$organism->id ?>" <?= (int)$organism->id === (int)$gene->organism_id ? 'selected' : '' ?>>
                        <?= htmlspecialchars($organism->name) ?>
                    </option>
                <?php endforeach; ?>
            </select>
            <div class="invalid-feedback">please select a target host organism sequence.</div>
        </div>

        <div class="mb-3 form-check">
            <input type="checkbox" name="reviewed" class="form-check-input" id="reviewed" <?= $gene->reviewed ? 'checked' : '' ?>>
            <label class="form-check-label" for="reviewed">Reviewed</label>
        </div>

        <button type="submit" class="btn btn-primary">Save Changes</button>
    </form>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('editGeneForm');

            // forces immediate validation check state on initial layout script parsing
            form.checkValidity();

            form.addEventListener('submit', function(e) {
                e.preventDefault();

                // blocks asynchronous execution steps if current input elements violate constraints
                if (!this.checkValidity()) {
                    e.stopPropagation();
                    return;
                }

                const id = document.getElementById('geneId').value;
                const payload = Object.fromEntries(new FormData(e.target));
                payload.reviewed = document.getElementById('reviewed').checked ? "1" : "0";

                fetch("/geneData/GeneDataItem/" + id, {
                    method: "PUT",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload)
                })
                    .then(async res => {
                        if (res.ok) {
                            window.location.href = "/geneData/GeneDataItem/" + id;
                        } else {
                            const err = await res.json().catch(() => ({}));
                            alert("Error: " + (err.error || "server error"));
                        }
                    })
                    .catch(() => alert("No connection to the server could be built."));
            });
        });
    </script>

