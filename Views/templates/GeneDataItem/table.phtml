<script>
    const sortDirections = {};

    function sortGeneTable(columnIndex) {
        const table = document.getElementById("gene-table");
        if (!table) {
            return;
        }

        const rows = Array.from(table.tBodies[0].rows);
        const ascending = !sortDirections[columnIndex];

        rows.sort((rowA, rowB) => {
            const valueA = rowA.cells[columnIndex].innerText.trim().toLowerCase();
            const valueB = rowB.cells[columnIndex].innerText.trim().toLowerCase();

            if (!isNaN(valueA) && !isNaN(valueB)) {
                return ascending ? valueA - valueB : valueB - valueA;
            }

            return ascending ? valueA.localeCompare(valueB) : valueB.localeCompare(valueA);
        });

        rows.forEach((row) => table.tBodies[0].appendChild(row));
        sortDirections[columnIndex] = ascending;

        for (let i = 0; i <= 5; i++) {
            document.getElementById("sort-arrow-" + i).innerHTML = "";
        }

        document.getElementById("sort-arrow-" + columnIndex).innerHTML = ascending ? " &uarr;" : " &darr;";
    }

    document.addEventListener("DOMContentLoaded", () => sortGeneTable(0));

    function deleteGeneDataItem(id) {
        if (!confirm("Delete this gene?")) {
            return;
        }

        fetch("/geneData/GeneDataItem/" + id, {
            method: "DELETE"
        }).then((response) => {
            if (response.ok) {
                location.reload();
                return;
            }

            alert("Gene could not be deleted.");
        });
    }
</script>

