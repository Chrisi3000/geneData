    <script>
        // Tracks toggle direction state per columnIndex keys
        const sortDirections = {};

        function sortGeneTable(columnIndex) {
            const table = document.getElementById("gene-table");
            if (!table) return;

            // Collects table body rows into an iterable Array to access array prototype sort features
            const rows = Array.from(table.tBodies[0].rows);
            const ascending = !sortDirections[columnIndex];

            rows.sort((rowA, rowB) => {
                const valueA = rowA.cells[columnIndex].innerText.trim().toLowerCase();
                const valueB = rowB.cells[columnIndex].innerText.trim().toLowerCase();

                // Evaluates and applies mathematical difference if comparing numeric column fields
                if (!isNaN(valueA) && !isNaN(valueB)) {
                    return ascending ? valueA - valueB : valueB - valueA;
                }

                // Fallback to alphabetical locale sorting structure for standard string sequences
                return ascending ? valueA.localeCompare(valueB) : valueB.localeCompare(valueA);
            });

            // Reappends sorted DOM elements. appendChild effectively shifts existing rows into their new positions
            rows.forEach((row) => table.tBodies[0].appendChild(row));
            sortDirections[columnIndex] = ascending; // Stores state change for subsequent toggle execution

            // Resets arrow symbols across all column headers before updating the current target element
            for (let i = 0; i <= 5; i++) {
                document.getElementById("sort-arrow-" + i).innerHTML = "";
            }

            // Renders unicode directional arrow pointing matching state logic direction
            document.getElementById("sort-arrow-" + columnIndex).innerHTML = ascending ? " &uarr;" : " &darr;";
        }

        // Forces initial table alignment ordering by Id index once layout parsing completes
        document.addEventListener("DOMContentLoaded", () => sortGeneTable(0));

        function deleteGeneDataItem(id) {
            if (!confirm("Delete this gene?")) return;

            // Dispatches standard DELETE method directly to the singular entity route
            fetch("/geneData/GeneDataItem/" + id, {
                method: "DELETE"
            }).then((response) => {
                if (response.ok) {
                    // Triggers structural grid interface update immediately on successful execution confirmation
                    location.reload();
                    return;
                }
                alert("Gene could not be deleted.");
            });
        }
    </script>

