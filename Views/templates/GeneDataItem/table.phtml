<?php include __DIR__ . "/../_header.phtml"; ?>
<?php /** @var Domains_GeneDataItem $data */ ?>
    <?php if($data) { ?>
        <table class="table table-striped table-hover table-bordered align-middle shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>GeneName</th>
                    <th>GeneSymbol</th>
                    <th>Position</th>
                    <th>Organism</th>
                    <th>Reviewed</th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($data as $obj){ ?>
                    <?php
                    $reviewed = strtolower((string)($obj->reviewed ?? ''));
                    $isReviewed = $reviewed === 'yes'
                            || $reviewed === 'true'
                            || $reviewed === '1'
                            || $reviewed === 'reviewed';
                    ?>

                   <tr>
                       <td class="fw-semibold"><?=$obj->id?></td>
                       <td><?=$obj->genename?></td>
                       <td>
                           <span class="badge bg-secondary">
                               <?=$obj->GeneSymbol?>
                           </span>
                       </td>
                       <td>
                           <code>
                               <?=$obj->position?>
                           </code>
                       </td>
                       <td><?=$obj->organism?></td>
                       <td>
                           <?php if ($isReviewed) { ?>
                               <span class="badge bg-success">
                                   &#10004; Reviewed
                               </span>
                           <?php } else { ?>
                               <span class="badge bg-danger">
                                   &#10008; Not reviewed
                               </span>
                           <?php } ?>
                       </td>
                   </tr>
                 <?php
                    }
                ?>
            </tbody>
        </table>
    <?php } else { ?>
        <div class="p-4 text-center">
